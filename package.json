{
  "name": "@vulcx/widget",
  "version": "0.2.2",
  "description": "Embeddable swap widget for the Vulcx DEX aggregator",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/vulcx-widget.umd.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vulcx/sdk": "^0.2.1"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "rollup": "^4.34.8",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/argyros-ag/widget"
  },
  "license": "MIT",
  "keywords": [
    "solana",
    "dex",
    "aggregator",
    "swap",
    "widget",
    "web-component",
    "vulcx"
  ]
}